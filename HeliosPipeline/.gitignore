node_modules/
**/node_modules/
dist/
build/
coverage/

# --- CONFIGURACIÓN LOCAL FRONTEND ---
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- DATOS E IMÁGENES (Prevenir subidas masivas) ---
data/raw/
data/processed/
