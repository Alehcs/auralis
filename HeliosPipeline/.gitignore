# --- DEPENDENCIAS Y ENTORNOS (PYTHON) ---
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
env/
.env
.venv

# --- DEPENDENCIAS Y BUILDS (NODE/REACT) ---
