!data/sample/
!data/sample/**

# --- MODELOS DE IA (Archivos pesados > 100MB) ---
*.pth
*.pt
*.onnx
models/helios_v2_pro.pth
# Si usas Git LFS para modelos, comenta las líneas anteriores

# --- LOGS Y BASES DE DATOS LOCALES ---
*.log
*.sqlite3
celerybeat-schedule

# --- SISTEMA OPERATIVO Y IDEs ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

