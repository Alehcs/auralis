node_modules/
**/node_modules/
dist/
build/
coverage/

# --- CONFIGURACIÓN LOCAL FRONTEND ---
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- DATOS E IMÁGENES (Prevenir subidas masivas) ---
data/raw/
data/processed/
# Excepción: muestra para demo (16 magnetogramas ~16 MB)
!data/sample/
!data/sample/**

# --- MODELOS DE IA (checkpoints pesados ignorados por defecto) ---
*.pth
*.pt
*.onnx
# Excepción: artefactos de producción promovidos (pequeños, deben clonarse) ---
# Coronium V3 PRO + ExtremeAug — checkpoint promovido (~829 KB)
!models/best_coronium_v3_pro_augmented.pth
# Grafo ONNX de producción (86.6 KB, opset 18) — su .onnx.data ya se versiona
!models/best_coronium_v3_pro.onnx
!models/target_scaler.json

